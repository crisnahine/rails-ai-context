#!/usr/bin/env ruby
# frozen_string_literal: true

# Standalone mode: the RubyGems exe wrapper activates our gem and all transitive
# dependencies BEFORE this script runs. When inside a Rails app, Bundler.setup
# may need different versions of those deps (e.g., bigdecimal 4.1.0 activated here
# but Gemfile.lock wants 4.0.1). Clear non-default gem activations so Bundler can
# resolve cleanly. The $LOAD_PATH entries remain (Bundler.setup replaces them anyway).
#
# Skip this when running under `bundle exec` — Bundler has already resolved gems
# correctly, and clearing specs breaks gems that look up their own path at runtime
# (e.g., MCP SDK reads Gem.loaded_specs["json-schema"].full_gem_path).
if defined?(Gem) && Gem.respond_to?(:loaded_specs) && !ENV["BUNDLE_BIN_PATH"]
  # Also strip the Rails-family gems' lib paths. Leaving them in $LOAD_PATH
  # lets the app's boot resolve framework files from the NEWEST installed
  # versions instead of the app's Gemfile.lock pins, producing a mixed
  # framework tree: wrong Rails.version in every generated fact and
  # "already initialized constant" double-load warnings. Every Rails app's
  # bundle provides these; in app-less modes a require re-activates them
  # fresh. Non-framework tooling deps (mcp and friends) must keep their
  # paths - Bundler.setup during app boot locks out late RubyGems
  # activation, and restore_standalone_environment! splices them back.
  rails_family = %w[
    rails railties activesupport activemodel activerecord actionpack
    actionview actionmailer activejob actioncable activestorage
    actionmailbox actiontext
  ].freeze
  Gem.loaded_specs.each_value do |spec|
    next if spec.default_gem? || !rails_family.include?(spec.name)
    spec.full_require_paths.each { |path| $LOAD_PATH.delete(path) }
  end
  Gem.loaded_specs.delete_if { |_, spec| !spec.default_gem? }
end

require "thor"
require "yaml"

# Top-level class to avoid conflict with RailsAiContext::CLI module (which contains ToolRunner).
# The library uses RailsAiContext::CLI as a module namespace; this exe needs a class for Thor.
class RailsAiContextCLI < Thor
    # Thor derives its namespace from the class name ("rails_ai_context_c_l_i")
    # and prints it as the root of the built-in `tree` command. Name it after
    # the binary so tree output matches what users actually type.
    namespace "rails-ai-context"

    # Without this, Thor exits 0 on an unrecognized command (and warns on
    # stderr that it will default to exit 1 in Thor 2.0). Scripts and AI
    # agents rely on a non-zero exit to detect a bad command.
    def self.exit_on_failure?
      true
    end

    # Let Thor pass unknown options through to ToolRunner for the tool command
    stop_on_unknown_option! :tool

    # Thor only recognizes bare subcommands by default; without this, `--version`
    # and `-v` fall through to "Could not find command" instead of the `version` task.
    map %w[--version -v] => :version

    class_option :app_path, type: :string,
      desc: "Path to the Rails app root (default: current directory)"
    class_option :environment, type: :string,
      desc: "RAILS_ENV to run under (default: the ambient RAILS_ENV or development)"

    desc "tool [NAME]", "Run an MCP tool. Use --list to see all."
    option :json, type: :boolean, default: false, desc: "Output as JSON envelope"
    option :list, type: :boolean, default: false, desc: "List available tools"
    option :no_boot, type: :boolean, default: false, desc: "Skip booting the app; serve static analysis only"
    def tool(name = nil, *args)
      if options[:list] || name.nil?
        print_tool_list
        return
      end

      if args.include?("--help") || args.include?("-h")
        require "rails_ai_context"
        tool_class = ::RailsAiContext::CLI::ToolRunner.new(name, []).tool_class
        puts ::RailsAiContext::CLI::ToolRunner.tool_help(tool_class)
        return
      end

      # `--json` is consumed as the Thor option only when it precedes the tool
      # name; `stop_on_unknown_option! :tool` passes it through into `args` when
      # it follows the name (the natural CLI position). Honor both placements by
      # also stripping it from args here, mirroring the --help handling above.
      json_mode = options[:json]
      json_mode = true if args.delete("--json")
      json_mode = true if args.delete("-j")

      # stop_on_unknown_option! passes post-name flags through into args;
      # honor --no-boot in either position, mirroring the --json handling.
      no_boot = options[:no_boot]
      no_boot = true if args.delete("--no-boot")

      # Same for the value-taking class options: after the tool name they
      # arrive as plain args, and dropping them silently sends the command
      # at the wrong app (or wrong RAILS_ENV).
      @app_path_override = extract_value_flag!(args, "--app-path")
      @environment_override = extract_value_flag!(args, "--environment")

      boot_rails!(allow_static: true, no_boot: no_boot)

      runner = ::RailsAiContext::CLI::ToolRunner.new(name, args, json_mode: json_mode)
      puts runner.run
      exit 1 if runner.error
    rescue SystemExit
      raise # let exit() propagate (from boot_rails!)
    rescue StandardError, ScriptError => e
      $stderr.puts "Error: #{e.message}"
      exit 1
    end

    desc "serve", "Start MCP server (stdio transport)"
    option :transport, type: :string, default: "stdio", desc: "Transport: stdio or http"
    option :port, type: :numeric, default: 6029, desc: "HTTP port (only for http transport)"
    option :no_boot, type: :boolean, default: false, desc: "Skip booting the app; serve static analysis only"
    def serve
      boot_rails!(allow_static: true)

      transport = options[:transport].to_sym
      if transport == :http
        ::RailsAiContext.configuration.http_port = options[:port]
      end

      ::RailsAiContext.start_mcp_server(transport: transport)
    rescue SystemExit
      raise
    rescue StandardError, ScriptError => e
      $stderr.puts "Error: #{e.message}"
      exit 1
    end

    desc "context", "Generate AI context files"
    option :format, type: :string, default: nil, desc: "Format: claude, cursor, copilot, json, all (default: from config)"
    def context
      boot_rails!

      if options[:format]
        cleanup_tools = options[:format] == "all" ? nil : [ options[:format].to_sym ]
      else
        cleanup_tools = ::RailsAiContext.configuration.ai_tools
      end
      ::RailsAiContext::LegacyCleanup.prompt_legacy_files(cleanup_tools, root: Dir.pwd)

      $stderr.puts "Introspecting Rails app..."

      if options[:format]
        # Explicit --format flag overrides config
        result = ::RailsAiContext.generate_context(format: options[:format].to_sym)
        print_context_result(result)
      else
        # Use ai_tools from config (.rails-ai-context.yml or initializer)
        ai_tools = ::RailsAiContext.configuration.ai_tools
        if ai_tools.nil? || ai_tools.empty?
          result = ::RailsAiContext.generate_context(format: :all)
          print_context_result(result)
        else
          # One call for every selected format so ContextFileSerializer's
          # cross-format dedup applies (opencode and codex share AGENTS.md
          # and its split rules - generating one format at a time defeats
          # that dedup and reports the same file as both written and
          # unchanged).
          result = ::RailsAiContext.generate_context(format: ai_tools)
          print_context_result(result)
        end
      end
    rescue SystemExit
      raise
    rescue StandardError, ScriptError => e
      $stderr.puts "Error: #{e.message}"
      exit 1
    end

    desc "inspect", "Print introspection summary"
    def inspect_app
      boot_rails!
      require "json"

      context = ::RailsAiContext.introspect
      puts JSON.pretty_generate(context)
    end

    # Thor registers commands under their Ruby method names, and this method
    # can't be called `inspect` (it would shadow Object#inspect). Re-key the
    # command so dispatch, `help inspect`, and `tree` all use the public name;
    # the command object still invokes inspect_app.
    commands["inspect"] = commands.delete("inspect_app")

    desc "watch", "Watch for changes and auto-regenerate context files"
    def watch
      boot_rails!
      ::RailsAiContext::Watcher.new.start
    end

    desc "doctor", "Run diagnostic checks and report AI readiness score"
    option :strict, type: :boolean, default: false, desc: "Exit 1 when any check fails (CI gate)"
    def doctor
      boot_rails!(context: "doctor")
      result = ::RailsAiContext::Doctor.new.run
      # The report is the command's product - it belongs on stdout so
      # `doctor > report.txt` captures it. stderr stays for errors only.
      result[:checks].each do |check|
        icon = case check.status
        when :pass then "PASS"
        when :warn then "WARN"
        when :fail then "FAIL"
        end
        puts "  [#{icon}] #{check.name}: #{check.message}"
        puts "         Fix: #{check.fix}" if check.fix
      end
      puts ""
      puts "AI Readiness Score: #{result[:score]}/100"

      failed = result[:checks].count { |c| c.status == :fail }
      if options[:strict] && failed > 0
        $stderr.puts "#{failed} check#{'s' unless failed == 1} failed (--strict)"
        exit 1
      end
    end

    desc "init", "Set up rails-ai-context for standalone use (creates .rails-ai-context.yml and .mcp.json)"
    def init
      config_path = File.join(Dir.pwd, "config", "environment.rb")
      unless File.exist?(config_path)
        $stderr.puts "Error: No Rails app found in #{Dir.pwd}"
        $stderr.puts "Run this command from your Rails app root directory."
        exit 1
      end

      # --- Read previous selection (before prompts) ---
      previous_tools = read_previous_ai_tools

      # --- Prompts (no Rails needed) ---
      ai_tools = prompt_ai_tools
      tool_mode = prompt_tool_mode

      # --- Cleanup removed tools ---
      cleanup_removed_tools(previous_tools, ai_tools) if previous_tools&.any?

      # --- One-time v5.0.0 legacy UI-pattern files cleanup prompt ---
      # Boot Rails lazily: we need the gem loaded to access LegacyCleanup.
      # But we avoid booting Rails here — require just the legacy_cleanup file.
      require_relative "../lib/rails_ai_context/legacy_cleanup"
      ::RailsAiContext::LegacyCleanup.prompt_legacy_files(ai_tools, root: Dir.pwd)

      # --- Write .rails-ai-context.yml ---
      write_yaml_config(ai_tools, tool_mode)

      # --- Write per-tool MCP config files (MCP mode only) ---
      write_mcp_configs(ai_tools, tool_mode)

      # --- Add .ai-context.json to .gitignore ---
      add_to_gitignore

      # --- Boot Rails, load config, generate context ---
      boot_rails!

      $stderr.puts ""
      $stderr.puts "Generating AI context files..."
      # One call for every selected format so ContextFileSerializer's
      # cross-format dedup applies (opencode and codex share AGENTS.md and
      # its split rules - generating one format at a time defeats that
      # dedup and reports the same file as both written and unchanged).
      result = ::RailsAiContext.generate_context(format: ai_tools)
      (result[:written] || []).each { |f| $stderr.puts "  Written: #{f}" }
      (result[:skipped] || []).each { |f| $stderr.puts "  Skipped: #{f} (unchanged)" }

      # --- Instructions ---
      show_standalone_instructions(ai_tools, tool_mode)
    end

    desc "preset NAME", "Run a multi-tool preset (architecture, debugging, migration)"
    def preset(name = nil)
      require_relative "../lib/rails_ai_context/presets"
      presets = ::RailsAiContext::Presets::DEFINITIONS

      unless name && presets.key?(name)
        $stderr.puts "Unknown preset: #{name}\n\n" if name
        $stderr.puts "Available presets:"
        $stderr.puts ""
        presets.each do |key, info|
          $stderr.puts "  rails-ai-context preset #{key}".ljust(45) + "# #{info[:desc]}"
        end
        # Bare `preset` is a listing request (exit 0); a name that matches no
        # preset is an input error, so scripts get a non-zero exit.
        exit 1 if name
        return
      end

      boot_rails!

      preset = presets[name]
      $stderr.puts "=" * 60
      $stderr.puts " Preset: #{name} - #{preset[:desc]}"
      $stderr.puts "=" * 60
      $stderr.puts ""

      preset[:tools].each do |tool_spec|
        begin
          $stderr.puts "-" * 40
          puts "Running: #{tool_spec[:name]}"
          $stderr.puts "-" * 40
          runner = ::RailsAiContext::CLI::ToolRunner.new(
            tool_spec[:name],
            tool_spec[:params]
          )
          puts runner.run
          puts ""
        rescue => e
          $stderr.puts "  [error] #{tool_spec[:name]}: #{e.message}"
        end
      end
    rescue SystemExit
      raise
    rescue StandardError, ScriptError => e
      $stderr.puts "Error: #{e.message}"
      exit 1
    end

    desc "facts", "Print concise schema facts summary (tables, associations, dependencies)"
    def facts
      boot_rails!

      context = ::RailsAiContext.introspect
      puts ::RailsAiContext::FactsFormatter.render(context, inspect_hint: "rails-ai-context inspect")
    rescue SystemExit
      raise
    rescue StandardError, ScriptError => e
      $stderr.puts "Error: #{e.message}"
      exit 1
    end

    desc "version", "Print version"
    def version
      require_relative "../lib/rails_ai_context/version"
      puts "rails-ai-context v#{RailsAiContext::VERSION}"
    end

    private

    AI_TOOL_OPTIONS = {
      "1" => { key: :claude,   name: "Claude Code",    files: "CLAUDE.md + .claude/rules/" },
      "2" => { key: :cursor,   name: "Cursor",         files: ".cursor/rules/ + .cursorrules (legacy fallback)" },
      "3" => { key: :copilot,  name: "GitHub Copilot", files: ".github/copilot-instructions.md + .github/instructions/" },
      "4" => { key: :opencode, name: "OpenCode",       files: "AGENTS.md" },
      "5" => { key: :codex,   name: "Codex CLI",      files: "AGENTS.md + .codex/config.toml" }
    }.freeze

    def prompt_ai_tools
      $stderr.puts ""
      $stderr.puts "Which AI tools do you use? (select all that apply)"
      $stderr.puts ""
      AI_TOOL_OPTIONS.each { |num, info| $stderr.puts "  #{num}. #{info[:name].ljust(16)} -> #{info[:files]}" }
      $stderr.puts "  a. All of the above"
      $stderr.puts ""
      $stderr.print "Enter numbers separated by commas (e.g. 1,2) or 'a' for all: "
      input = $stdin.gets&.strip&.downcase || "a"

      selected = if input == "a" || input == "all" || input.empty?
        AI_TOOL_OPTIONS.values.map { |t| t[:key] }
      else
        input.split(/[\s,]+/).filter_map { |n| AI_TOOL_OPTIONS[n]&.dig(:key) }
      end

      if selected.empty?
        $stderr.puts "No tools selected — using all."
        selected = AI_TOOL_OPTIONS.values.map { |t| t[:key] }
      end

      names = AI_TOOL_OPTIONS.values.select { |t| selected.include?(t[:key]) }.map { |t| t[:name] }
      $stderr.puts "Selected: #{names.join(', ')}"
      selected
    end

    def prompt_tool_mode
      $stderr.puts ""
      $stderr.puts "Do you also want MCP server support?"
      $stderr.puts ""
      $stderr.puts "  1. Yes — MCP server (generates per-tool MCP config files)"
      $stderr.puts "  2. No  — CLI only (no server needed)"
      $stderr.puts ""
      $stderr.print "Enter number (default: 1): "
      input = $stdin.gets&.strip || "1"

      mode = input == "2" ? :cli : :mcp
      label = mode == :mcp ? "MCP server" : "CLI only"
      $stderr.puts "Selected: #{label}"
      mode
    end

    # Files/dirs generated per AI tool format — used for cleanup on tool removal.
    # MCP config files are NOT listed here — they use merge-safe removal via
    # McpConfigGenerator.remove to preserve other servers' entries.
    FORMAT_PATHS = {
      claude:   %w[CLAUDE.md .claude/rules],
      cursor:   %w[.cursor/rules .cursorrules],
      copilot:  %w[.github/copilot-instructions.md .github/instructions],
      opencode: %w[AGENTS.md app/models/AGENTS.md app/controllers/AGENTS.md],
      codex:    %w[AGENTS.md app/models/AGENTS.md app/controllers/AGENTS.md]
    }.freeze

    def read_previous_ai_tools
      yaml_path = File.join(Dir.pwd, ".rails-ai-context.yml")
      return nil unless File.exist?(yaml_path)

      data = YAML.safe_load_file(yaml_path, permitted_classes: [ Symbol ]) || {}
      tools = data["ai_tools"]
      return nil unless tools.is_a?(Array) && tools.any?

      tools.map(&:to_sym)
    rescue => e
      $stderr.puts "[rails-ai-context] Could not read previous config: #{e.message}" if ENV["DEBUG"]
      nil
    end

    def cleanup_removed_tools(previous, current)
      removed = previous.map(&:to_sym) - current.map(&:to_sym)
      return if removed.empty?

      $stderr.puts ""
      $stderr.puts "These AI tools were removed from your selection:"
      removed.each_with_index do |fmt, idx|
        tool = AI_TOOL_OPTIONS.values.find { |t| t[:key] == fmt }
        $stderr.puts "  #{idx + 1}. #{tool[:name]} (#{tool[:files]})" if tool
      end
      $stderr.puts ""
      $stderr.puts "Remove their generated files?"
      $stderr.puts "  y — remove all listed above"
      $stderr.puts "  n — keep all (default)"
      $stderr.puts "  1,2 — remove only specific ones by number"
      $stderr.puts ""
      $stderr.print "Enter choice: "
      input = $stdin.gets&.strip&.downcase || "n"
      return if input.empty? || input == "n" || input == "no"

      to_remove = if input == "y" || input == "yes" || input == "a"
        removed
      else
        nums = input.split(/[\s,]+/).filter_map { |n| n.to_i - 1 }
        nums.filter_map { |i| removed[i] if i >= 0 && i < removed.size }
      end

      return if to_remove.empty?

      require "fileutils"
      # Collect paths still needed by remaining tools to avoid deleting shared files
      kept_paths = current.map(&:to_sym).flat_map { |f| FORMAT_PATHS[f] || [] }.to_set

      to_remove.each do |fmt|
        tool = AI_TOOL_OPTIONS.values.find { |t| t[:key] == fmt }

        # Remove context files (skip if another selected tool still needs them)
        paths = FORMAT_PATHS[fmt] || []
        paths.each do |rel_path|
          next if kept_paths.include?(rel_path)

          full = File.join(Dir.pwd, rel_path)
          if File.directory?(full)
            FileUtils.rm_rf(full)
            $stderr.puts "  Removed #{rel_path}/"
          elsif File.exist?(full)
            FileUtils.rm_f(full)
            $stderr.puts "  Removed #{rel_path}"
          end
        end

        # Merge-safe MCP config cleanup — removes only the rails-ai-context entry
        cleaned = RailsAiContext::McpConfigGenerator.remove(tools: [ fmt ], output_dir: Dir.pwd)
        cleaned.each { |f| $stderr.puts "  Removed MCP entry from #{File.basename(f)}" }

        $stderr.puts "  #{tool[:name]} files removed" if tool
      end
    end

    def add_to_gitignore
      gitignore = File.join(Dir.pwd, ".gitignore")
      return unless File.exist?(gitignore)

      content = File.read(gitignore)
      lines = []
      unless content.include?(".ai-context.json")
        lines << ""
        lines << "# rails-ai-context (JSON cache - markdown files should be committed)"
        lines << ".ai-context.json"
      end
      unless content.include?(".codex/config.toml")
        lines << ""
        lines << "# rails-ai-context (embeds this machine's Ruby PATH/GEM_HOME - do not share)"
        lines << ".codex/config.toml"
      end
      return if lines.empty?

      File.open(gitignore, "a") { |f| lines.each { |line| f.puts line } }
      $stderr.puts "Updated .gitignore"
    end

    def write_yaml_config(ai_tools, tool_mode)
      yaml_path = File.join(Dir.pwd, ".rails-ai-context.yml")
      content = {
        "ai_tools" => ai_tools.map(&:to_s),
        "tool_mode" => tool_mode.to_s
      }
      new_content = YAML.dump(content)
      existed = File.exist?(yaml_path)

      if existed && File.read(yaml_path) == new_content
        $stderr.puts ".rails-ai-context.yml (unchanged)"
      else
        File.write(yaml_path, new_content)
        $stderr.puts "#{existed ? 'Updated' : 'Created'} .rails-ai-context.yml"
      end
    end

    def write_mcp_configs(ai_tools, tool_mode)
      require_relative "../lib/rails_ai_context/mcp_config_generator"
      # No explicit standalone: flag - the generator detects the install mode
      # from Gemfile.lock, so this writes the same command form as the rake
      # task and Rails generator for the same app (no config ping-pong).
      generator = ::RailsAiContext::McpConfigGenerator.new(
        tools: ai_tools,
        output_dir: Dir.pwd,
        tool_mode: tool_mode
      )
      result = generator.call
      result[:written].each { |f| $stderr.puts "  Created/Updated #{f}" }
      result[:skipped].each { |f| $stderr.puts "  #{f} unchanged — skipped" }
    end

    def show_standalone_instructions(ai_tools, tool_mode)
      $stderr.puts ""
      $stderr.puts "=" * 50
      $stderr.puts " rails-ai-context initialized!"
      $stderr.puts "=" * 50
      $stderr.puts ""
      $stderr.puts "Your setup:"
      AI_TOOL_OPTIONS.each_value do |info|
        next unless ai_tools.include?(info[:key])
        $stderr.puts "  #{info[:name].ljust(16)} -> #{info[:files]}"
      end
      $stderr.puts ""
      $stderr.puts "Commands:"
      $stderr.puts "  rails-ai-context context    # Regenerate context files"
      $stderr.puts "  rails-ai-context tool NAME  # Run any of the #{tool_count_str} tools"
      if tool_mode == :mcp
        $stderr.puts "  rails-ai-context serve      # Start MCP server"
      end
      $stderr.puts "  rails-ai-context doctor     # Check AI readiness"
      $stderr.puts ""
      if tool_mode == :mcp
        $stderr.puts "MCP auto-discovery:"
        $stderr.puts "  Each AI tool gets its own config file — auto-detected on project open."
        $stderr.puts "  No manual config needed."
      else
        $stderr.puts "CLI tools:"
        $stderr.puts "  AI agents can run `rails-ai-context tool schema table=users` directly."
      end
      $stderr.puts ""
      $stderr.puts "Config: .rails-ai-context.yml (edit anytime, no restart needed)"
      $stderr.puts ""
    end

    def tool_count_str
      if defined?(::RailsAiContext::Server)
        ::RailsAiContext::Server.builtin_tools.size.to_s
      else
        "38"
      end
    end

    def print_context_result(result)
      (result[:written] || []).each { |f| $stderr.puts "  Written: #{f}" }
      (result[:skipped] || []).each { |f| $stderr.puts "  Skipped: #{f} (unchanged)" }
    end

    # The tool list only needs tool names/descriptions/schemas - none of that
    # depends on a booted app (routes loaded, DB connected, etc.), so it
    # shouldn't require one. Boot normally when there's an app to boot (so
    # config-driven filtering like skip_tools/custom_tools still applies);
    # otherwise load the gem standalone and list from that. Only execution
    # (running a specific tool) genuinely needs a live app.
    def print_tool_list
      config_path = File.join(Dir.pwd, "config", "environment.rb")
      if File.exist?(config_path) && try_boot_for_list
        puts ::RailsAiContext::CLI::ToolRunner.tool_list
        return
      end

      begin
        require "rails_ai_context"
        puts ::RailsAiContext::CLI::ToolRunner.tool_list
        puts ""
        puts "Run inside a Rails app to execute tools - static source analysis works even when the app can't boot (see --no-boot)."
      rescue LoadError, StandardError => e
        $stderr.puts "Error: No Rails app found in #{Dir.pwd}"
        $stderr.puts "Run this command from your Rails app root directory."
        $stderr.puts "  (gem also failed to load standalone: #{e.message})" if ENV["DEBUG"]
        exit 1
      end
    end

    # Attempts the normal boot path, catching the `exit 1` boot_rails! raises
    # on a missing app or a failed boot (both come through as SystemExit).
    # Returns true only when the app booted successfully; other `tool`
    # subcommands don't have a fallback so they call boot_rails! directly and
    # let that exit propagate.
    def try_boot_for_list
      boot_rails!
      true
    rescue SystemExit
      false
    end

    # Gems that the MCP SDK reads from `Gem.loaded_specs` at tool-call time
    # (specifically `Gem.loaded_specs["json-schema"].full_gem_path` in
    # mcp/tool/schema.rb). Bundler.setup strips them in standalone mode so we
    # capture references BEFORE Rails boot runs and re-register them afterwards.
    STANDALONE_REQUIRED_GEMS = %w[mcp json-schema addressable public_suffix].freeze

    # Pull a value-taking flag (--flag VALUE or --flag=VALUE) out of the
    # pass-through args that stop_on_unknown_option! leaves after the tool
    # name. Returns the value, or nil when the flag isn't present.
    def extract_value_flag!(args, flag)
      if (idx = args.index(flag))
        args.delete_at(idx)
        return args.delete_at(idx)
      end
      if (pair = args.find { |a| a.start_with?("#{flag}=") })
        args.delete(pair)
        return pair.split("=", 2)[1]
      end
      nil
    end

    def boot_rails!(context: nil, allow_static: false, no_boot: false)
      app_path_opt = @app_path_override || options[:app_path]
      environment_opt = @environment_override || options[:environment]
      app_root = File.expand_path(app_path_opt || Dir.pwd)
      # Relative paths inside the app (log/, tmp/, sqlite files) assume the
      # process cwd is the app root, so honor --app-path by moving there.
      Dir.chdir(app_root) if app_path_opt
      ENV["RAILS_ENV"] = environment_opt if environment_opt

      if allow_static && (no_boot || options[:no_boot])
        enter_static_tier!("static mode requested with --no-boot")
        return
      end

      config_path = File.join(Dir.pwd, "config", "environment.rb")
      unless File.exist?(config_path)
        $stderr.puts "Error: No Rails app found in #{Dir.pwd}"
        $stderr.puts "Run this command from your Rails app root directory (or pass --app-path)."
        exit 1
      end

      require_relative "../lib/rails_ai_context/boot_manager"

      # Save $LOAD_PATH before Rails boot.
      # Bundler.setup (in config/boot.rb) strips $LOAD_PATH to Gemfile-only gems.
      # In standalone mode (gem not in Gemfile), this removes our gem and mcp paths.
      # We restore them after boot so lazy requires (mcp, etc.) still resolve.
      pre_boot_paths = $LOAD_PATH.dup

      # Capture spec references BEFORE Bundler.setup runs. After Bundler.setup,
      # Gem::Specification.find_by_name is filtered to only Gemfile-resolved gems
      # and our transitive deps (mcp, json-schema) become invisible — find_by_name
      # raises Gem::MissingSpecError. Capturing first means we hold real spec
      # objects we can splice back in after boot. No-op in in-Gemfile mode (the
      # captured specs already exist in Gem.loaded_specs and our `||=` skips them).
      pre_boot_specs = capture_standalone_specs

      # Standalone mode on Ruby 3.4+: this CLI process lazily activates the
      # newest/default version of stdlib gems (e.g. psych via `require "yaml"`,
      # date via transitive requires) BEFORE the app's Bundler.setup runs inside
      # the boot require. If the app resolves a different version, Bundler
      # raises `Gem::LoadError: already activated psych 5.4.0, but your Gemfile
      # requires psych 5.3.1`. Clear the pre-activated specs so Bundler activates
      # the versions the app resolves. No-op under `bundle exec`, so in-Gemfile
      # mode is unaffected.
      drop_conflicting_gem_activations!

      timeout = begin
        Integer(ENV.fetch("RAILS_AI_CONTEXT_BOOT_TIMEOUT",
                          ::RailsAiContext::BootManager::DEFAULT_TIMEOUT))
      rescue ArgumentError
        $stderr.puts "[rails-ai-context] WARNING: RAILS_AI_CONTEXT_BOOT_TIMEOUT=#{ENV['RAILS_AI_CONTEXT_BOOT_TIMEOUT']} is not a number - using #{::RailsAiContext::BootManager::DEFAULT_TIMEOUT}s"
        ::RailsAiContext::BootManager::DEFAULT_TIMEOUT
      end
      result = ::RailsAiContext::BootManager.boot!(app_root: Dir.pwd, timeout: timeout)

      unless result.booted?
        if allow_static
          $stderr.puts "[rails-ai-context] App boot failed: #{result.failure_summary}"
          if result.error.is_a?(::RailsAiContext::BootManager::BootTimeoutError)
            $stderr.puts "[rails-ai-context]   If the app is healthy but slow, raise RAILS_AI_CONTEXT_BOOT_TIMEOUT (seconds, current: #{timeout})."
          end
          $stderr.puts "[rails-ai-context] Serving static analysis; runtime-only data is marked [UNAVAILABLE]."
          $stderr.puts "[rails-ai-context] Run `rails-ai-context doctor` for boot diagnostics."
          restore_standalone_environment!(pre_boot_paths, pre_boot_specs)
          enter_static_tier!(result.failure_summary)
          return
        end

        $stderr.puts "Error: Rails app failed to boot in #{Dir.pwd}"
        $stderr.puts "  #{result.failure_summary}"
        if ENV["DEBUG"]
          Array(result.error.backtrace).first(15).each { |line| $stderr.puts "    #{line}" }
        else
          $stderr.puts "  Run with DEBUG=1 for the full backtrace."
        end

        if result.error.is_a?(::RailsAiContext::BootManager::BootTimeoutError)
          $stderr.puts "  The app took longer than #{timeout}s to boot. Raise the limit with"
          $stderr.puts "  RAILS_AI_CONTEXT_BOOT_TIMEOUT=<seconds> (current: #{timeout}s)."
        else
          $stderr.puts "  Common causes: missing ENV vars or credentials, an initializer"
          $stderr.puts "  that needs a service (database, Redis), or a syntax error."
          $stderr.puts "  If the app is healthy but slow to boot, raise RAILS_AI_CONTEXT_BOOT_TIMEOUT (seconds, default 60)."
        end

        $stderr.puts "  doctor needs a bootable app; fix the boot error above first." if context == "doctor"

        exit 1
      end

      restore_standalone_environment!(pre_boot_paths, pre_boot_specs)

      require "rails_ai_context"

      if defined?(Rails::VERSION::MAJOR) && Rails::VERSION::MAJOR >= 9
        $stderr.puts "[rails-ai-context] WARNING: Rails #{Rails.version} is newer than this gem supports (< 9.0)."
        $stderr.puts "[rails-ai-context]   Introspection is untested on this version and may be wrong or incomplete."
        $stderr.puts "[rails-ai-context]   Check for a newer rails-ai-context release."
      end

      RailsAiContext::Configuration.auto_load!
    end

    # Bundler.setup during app boot strips $LOAD_PATH and the spec registry
    # to Gemfile-resolved gems; in standalone mode our own transitive deps
    # (mcp, json-schema) vanish. Splice back what was captured pre-boot.
    def restore_standalone_environment!(pre_boot_paths, pre_boot_specs)
      (pre_boot_paths - $LOAD_PATH).each { |p| $LOAD_PATH << p }
      pre_boot_specs.each { |name, spec| Gem.loaded_specs[name] ||= spec }

      missing = STANDALONE_REQUIRED_GEMS.reject { |g| Gem.loaded_specs.key?(g) }
      return if missing.none? || ENV["BUNDLE_BIN_PATH"]

      $stderr.puts "[rails-ai-context] WARNING: standalone CLI could not restore gemspec(s): #{missing.join(', ')}."
      $stderr.puts "[rails-ai-context]   Tool calls may crash with `undefined method 'full_gem_path' for nil`."
      $stderr.puts "[rails-ai-context]   Try `gem install rails-ai-context` to ensure all transitive deps are installed."
    end

    # Static tier: the gem loads standalone (no app constants), introspection
    # runs against the filesystem, and every tool response carries the tier
    # banner so consumers know runtime data is absent.
    def enter_static_tier!(reason)
      require "rails_ai_context"
      ::RailsAiContext.tier = :static
      ::RailsAiContext.static_reason = reason
      ::RailsAiContext.configuration.app_root = Dir.pwd
      ::RailsAiContext::Configuration.auto_load!
      $stderr.puts "[rails-ai-context] static tier active: #{reason}"
    end

    # Look up each required gem via Gem::Specification.find_by_name BEFORE
    # Bundler.setup runs and filters the spec registry. Returns a hash of
    # {gem_name => Gem::Specification}. In in-Gemfile mode the lookups still
    # succeed but the result is unused (Bundler keeps these specs registered).
    def capture_standalone_specs
      return {} unless defined?(Gem) && Gem.respond_to?(:loaded_specs)

      STANDALONE_REQUIRED_GEMS.each_with_object({}) do |gem_name, acc|
        spec = Gem::Specification.find_by_name(gem_name)
        acc[gem_name] = spec if spec
      rescue Gem::MissingSpecError, Gem::LoadError
        # The gem is not installed at all (not just Bundler-filtered). Skip
        # silently — the downstream `require` produces a clearer error.
        next
      end
    end

    # Remove activated gem specs whose version differs from the app's
    # Gemfile.lock pin, so the app's Bundler.setup can activate the locked
    # version instead of raising `Gem::LoadError: already activated`. Only the
    # in-memory spec registration is removed; already-loaded stdlib code stays,
    # which is safe (require is idempotent and the affected gems - psych, date,
    # bigdecimal, stringio - keep stable APIs across the involved versions).
    # No-op under `bundle exec` (BUNDLE_BIN_PATH set): Bundler already governs
    # activation there, so in-Gemfile mode is untouched.
    def drop_conflicting_gem_activations!
      return if ENV["BUNDLE_BIN_PATH"]
      return unless defined?(Gem) && Gem.respond_to?(:loaded_specs)

      # Drop every pre-activated spec except bundler (which is mid-execution),
      # so the app's Bundler.setup activates each gem at the version IT resolves
      # rather than colliding with whatever RubyGems pre-activated. Without this,
      # `require config_path` raises `Gem::LoadError: already activated psych
      # 5.4.0, but your Gemfile requires psych 5.3.1`. Only the in-memory spec
      # registration is removed; already-loaded code stays (require is
      # idempotent). The gem's own spec and its MCP deps are captured before
      # this call and restored after boot (see capture_standalone_specs).
      Gem.loaded_specs.delete_if { |name, _| name != "bundler" }
    rescue => e
      $stderr.puts "[rails-ai-context] drop_conflicting_gem_activations! failed: #{e.message}" if ENV["DEBUG"]
    end
end

RailsAiContextCLI.start(ARGV)
